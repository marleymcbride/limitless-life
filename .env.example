# Limitless Life - Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# PostgreSQL database URL
DATABASE_URL=postgresql://user:password@localhost:5432/limitless_life

# ===================================================================
# STRIPE CONFIGURATION
# ===================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret for webhook signature verification
# Get it from: Stripe Dashboard → Developers → Webhooks → Click webhook → Signing secret
# Starts with: whsec_
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Pricing tiers (in cents, e.g., 299700 = $2997.00) - DEPRECATED
# Kept for reference only - using Stripe Price IDs below
PRICE_BETA=135700
PRICE_LIMITLESSPROTOCOL=29700
PRICE_LIMITLESSLIFE=259700
PRICE_LIMITLESSLIFEWHATSAPP=439700
PRICE_LIMITLESSHEALTHCONCIERGE=689700

# Stripe Price IDs for Pricing Selector
# Create these in Stripe Dashboard → Products → Create product → Add pricing
# Each tier needs: weekly, 3pay, 2pay, full payment options

# Protocol (1 price)
STRIPE_PRICE_PROTOCOL_FULL=price_protocol_full_placeholder

# Limitless Life (4-month program) - 4 prices
STRIPE_PRICE_LIFE_WEEKLY=price_life_weekly_placeholder
STRIPE_PRICE_LIFE_3PAY=price_life_3pay_placeholder
STRIPE_PRICE_LIFE_2PAY=price_life_2pay_placeholder
STRIPE_PRICE_LIFE_FULL=price_life_full_placeholder

# Limitless Life + WhatsApp (4-month program) - 4 prices
STRIPE_PRICE_WHATSAPP_WEEKLY=price_whatsapp_weekly_placeholder
STRIPE_PRICE_WHATSAPP_3PAY=price_whatsapp_3pay_placeholder
STRIPE_PRICE_WHATSAPP_2PAY=price_whatsapp_2pay_placeholder
STRIPE_PRICE_WHATSAPP_FULL=price_whatsapp_full_placeholder

# Limitless Health Concierge (6-month program) - 4 prices
STRIPE_PRICE_CONCIERGE_WEEKLY=price_concierge_weekly_placeholder
STRIPE_PRICE_CONCIERGE_6PAY=price_concierge_6pay_placeholder
STRIPE_PRICE_CONCIERGE_3PAY=price_concierge_3pay_placeholder
STRIPE_PRICE_CONCIERGE_FULL=price_concierge_full_placeholder

# ===================================================================
# N8N WEBHOOK CONFIGURATION
# ===================================================================
# Server-side webhook URL for n8n workflows (do NOT use NEXT_PUBLIC_ prefix)
# This is NOT exposed to the client
N8N_WEBHOOK_URL=https://n8n.marleymcbride.co/webhook

# API key for webhook polling endpoints (protects /api/webhooks/* routes)
# Generate a secure random string (e.g., openssl rand -base64 32)
WEBHOOKS_API_KEY=your_secure_api_key_here

# API key for n8n webhook authentication (protects event tracking webhooks)
# Generate a secure random string (e.g., openssl rand -base64 32)
WEBHOOK_API_KEY=your_secure_webhook_api_key_here

# ===================================================================
# APPLICATION CONFIGURATION
# ===================================================================
# Base URL for your application (used in Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# For production, use your actual domain:
# NEXT_PUBLIC_BASE_URL=https://yourdomain.com
